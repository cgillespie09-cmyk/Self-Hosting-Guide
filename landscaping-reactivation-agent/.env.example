## Twilio credentials — https://console.twilio.com
## These are just initial defaults; once the server is running you can also
## set/update them from the web dashboard at http://localhost:3000
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=+15555550123

## Your business info, used in message templates
BUSINESS_NAME=Green Acres Landscaping
BOOKING_URL=https://example.com/book

## Reply server / dashboard
PORT=3000

## Required to access the web dashboard (the /sms webhook stays open either way)
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=change-me

## Delay between each blast message, in milliseconds (avoid carrier rate limits)
BLAST_DELAY_MS=1100
